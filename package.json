{
  "name": "ts-activity-keeper",
  "version": "0.0.2",
  "description": "TS Activity Keeper for TS Dashboard — Electron macOS app",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "test": "node --test"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.ts.activity-keeper",
    "productName": "TS Activity Keeper",
    "afterPack": "build/afterPack.js",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.icns",
      "darkModeSupport": true,
      "target": [
        "dmg"
      ]
    },
    "files": [
      "src/**/*"
    ]
  }
}
